{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.rsdouglas/janee",
  "description": "Secrets management for AI agents via MCP. Securely inject credentials into tool calls.",
  "repository": {
    "url": "https://github.com/rsdouglas/janee",
    "source": "github"
  },
  "version": "0.8.4",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@true-and-useful/janee",
      "version": "0.8.4",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Path to secrets configuration file",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "JANEE_CONFIG"
        }
      ]
    }
  ]
}
